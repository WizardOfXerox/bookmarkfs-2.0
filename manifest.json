{
    "name": "BookmarkFS",
    "description": "A local file storage, notes, and utilities manager built on browser bookmark sync structures.",
    "version": "2.0",
    "default_locale": "en",
    "manifest_version": 3,
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "icons": {
        "16": "icons/16x16.png",
        "32": "icons/32x32.png",
        "64": "icons/64x64.png",
        "128": "icons/128x128.png",
        "256": "icons/256x256.png",
        "512": "icons/512x512.png",
        "1024": "icons/1024x1024.png"
    },
    "options_ui": {
        "open_in_tab": true,
        "page": "./dist/index.html"
    },
    "action": {
        "title": "BookmarkFS"
    },
    "side_panel": {
        "default_path": "./dist/index.html"
    },
    "web_accessible_resources": [{
        "resources": ["dist/unrar.wasm"],
        "matches": ["<all_urls>"]
    }],
    "sandbox": {
        "pages": ["dist/sandbox.html"]
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'",
        "sandbox": "sandbox allow-scripts; script-src 'self' 'unsafe-eval' 'wasm-unsafe-eval'; object-src 'self'"
    },
    "permissions": [
        "bookmarks",
        "storage",
        "contextMenus",
        "sidePanel",
        "unlimitedStorage",
        "tabGroups",
        "topSites",
        "declarativeNetRequest",
        "tabs",
        "webNavigation",
        "scripting",
        "downloads",
        "alarms",
        "notifications"
    ],
    "optional_permissions": [
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["dist/password_autofill.js"],
            "css": ["dist/password_autofill.css"],
            "run_at": "document_idle",
            "all_frames": false
        }
    ]
}

